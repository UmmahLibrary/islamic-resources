{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "resource.schema.json",
  "title": "Islamic Resource",
  "type": "object",
  "required": ["id", "name", "description", "category", "url", "license", "languages", "format", "free", "auth_required", "scholar_reviewed", "maintained", "tags", "added"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique kebab-case identifier, matches the filename"
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["quran", "hadith", "prayer-times", "tafsir", "duas", "calendar", "names", "fonts", "general"]
    },
    "subcategory": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "docs": { "type": "string", "format": "uri" },
    "repo": { "type": "string", "format": "uri" },
    "package": {
      "type": "string",
      "description": "Exact install/import name for package formats (npm, pip, cargo, pub, swift, maven). Used verbatim in quick-start snippets."
    },
    "endpoint": {
      "type": "string",
      "format": "uri",
      "description": "Example request URL for rest-api/graphql/data formats. Used verbatim in quick-start snippets instead of the landing url."
    },
    "license": { "type": "string" },
    "languages": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "format": {
      "type": "string",
      "enum": ["rest-api", "npm", "pip", "swift", "maven", "cargo", "pub", "json", "xml", "csv", "graphql", "sqlite", "source", "font", "image"]
    },
    "free": { "type": "boolean" },
    "auth_required": { "type": "boolean" },
    "scholar_reviewed": { "type": "boolean" },
    "maintained": { "type": "boolean" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "adapter": {
      "type": "string",
      "description": "npm import path for the adapter, e.g. @islamic-resources/adapters/quran-com"
    },
    "added": { "type": "string", "format": "date" },
    "attribution": { "type": "string" }
  }
}
