---
import type { Resource } from '@islamic-resources/adapters';
import { catLabel, catIcon, flagIcon, fmtShort } from '../lib/ui';

interface Props {
  resource: Resource;
}
const { resource: r } = Astro.props;
---

<article class="rc">
  <div class="rc-top">
    <span class="rc-glyph" set:html={catIcon(r.category, 18)} />
    <div class="rc-headings">
      <div class="rc-cat">{catLabel(r.category)}</div>
      <h3 class="rc-name">
        <a href={`/resources/${r.id}`} class="rc-stretch">{r.name}</a>
      </h3>
    </div>
    <span class="rc-license" title={r.license}>{r.license}</span>
  </div>

  <p class="rc-desc">{r.description}</p>

  <div class="rc-row">
    <span class="rc-format">{r.format}</span>
  </div>

  <div class="rc-row">
    {r.free && <span class="flag ok"><span set:html={flagIcon('free')} />Free</span>}
    {r.auth_required && <span class="flag warn"><span set:html={flagIcon('auth')} />Auth</span>}
    {r.maintained && <span class="flag ok"><span set:html={flagIcon('maint')} />Maintained</span>}
    {r.scholar_reviewed && <span class="flag gold"><span set:html={flagIcon('scholar')} />Scholar</span>}
  </div>

  <div class="rc-foot">
    <a class="rc-btn primary" href={r.url} target="_blank" rel="noopener">Open ↗</a>
    {r.docs && <a class="rc-btn" href={r.docs} target="_blank" rel="noopener">Docs</a>}
    {r.repo && <a class="rc-btn" href={r.repo} target="_blank" rel="noopener">Repo</a>}
    <div style="flex:1"></div>
    <span class="rc-date">{fmtShort(r.added)}</span>
  </div>
</article>

<style>
  .rc {
    position: relative;
    display: flex; flex-direction: column; gap: 12px;
    padding: 18px; border-radius: 14px;
    border: 1px solid var(--noor-border); background: var(--noor-card);
    transition: border-color 0.15s, transform 0.15s, background 0.15s;
    animation: noorIn 0.35s ease both;
    height: 100%;
  }
  .rc:hover { border-color: var(--noor-gold-dim); background: var(--noor-card-hi); transform: translateY(-3px); }
  .rc:focus-within { border-color: var(--noor-gold); box-shadow: 0 0 0 3px var(--noor-gold-soft); }

  .rc-top { display: flex; align-items: flex-start; gap: 11px; }
  .rc-glyph {
    display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: 10px; flex: none;
    background: var(--noor-gold-soft); color: var(--noor-gold);
  }
  .rc-headings { flex: 1; min-width: 0; }
  .rc-cat {
    font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--noor-faint); font-weight: 600; margin-bottom: 2px;
  }
  .rc-name {
    font-size: 16px; font-weight: 700; color: var(--noor-fg); line-height: 1.2;
    margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .rc-stretch { outline: none; }
  .rc-stretch::after { content: ''; position: absolute; inset: 0; border-radius: 14px; }
  .rc-license {
    font-size: 10px; font-weight: 600; color: var(--noor-faint);
    border: 1px solid var(--noor-border-soft); border-radius: 6px; padding: 2px 7px;
    flex: none; letter-spacing: 0.02em; white-space: nowrap;
    max-width: 120px; overflow: hidden; text-overflow: ellipsis;
  }

  .rc-desc {
    margin: 0; font-size: 13.5px; line-height: 1.5; color: var(--noor-muted);
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }

  .rc-row { display: flex; flex-wrap: wrap; gap: 6px; }
  .rc-format {
    font-family: var(--mono); font-size: 11px; color: var(--noor-muted);
    background: var(--noor-bg2); border: 1px solid var(--noor-border-soft);
    border-radius: 6px; padding: 2px 8px;
  }
  .flag {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 11px; font-weight: 500; border-radius: 999px; padding: 2px 9px;
  }
  .flag.ok { color: var(--ok); background: color-mix(in oklab, var(--ok) 13%, transparent); border: 1px solid color-mix(in oklab, var(--ok) 28%, transparent); }
  .flag.warn { color: var(--warn); background: color-mix(in oklab, var(--warn) 13%, transparent); border: 1px solid color-mix(in oklab, var(--warn) 28%, transparent); }
  .flag.gold { color: var(--noor-gold); background: var(--noor-gold-soft); border: 1px solid var(--noor-gold-dim); }

  .rc-foot {
    display: flex; align-items: center; gap: 8px; margin-top: 2px;
    padding-top: 12px; border-top: 1px solid var(--noor-border-soft);
  }
  .rc-btn {
    position: relative; z-index: 1;
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 12px; font-weight: 600; border-radius: 8px; padding: 6px 11px;
    color: var(--noor-fg); background: var(--noor-bg2);
    border: 1px solid var(--noor-border-soft); transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .rc-btn:hover { border-color: var(--noor-gold-dim); color: var(--noor-gold); }
  .rc-btn.primary { color: var(--noor-gold); background: var(--noor-gold-soft); border-color: var(--noor-gold-dim); }
  .rc-btn.primary:hover { background: color-mix(in oklab, var(--noor-gold) 22%, transparent); }
  .rc-date { font-size: 11px; color: var(--noor-faint); font-family: var(--mono); }
</style>
