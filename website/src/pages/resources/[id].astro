---
import Base from '../../layouts/Base.astro';
import registry from '../../../../registry/index.json';
import type { Resource } from '@islamic-resources/adapters';
import { catLabel, catIcon, flagIcon, fmtLong, langList, makeTabs, ICONS } from '../../lib/ui';

export function getStaticPaths() {
  return (registry.resources as Resource[]).map((r) => ({
    params: { id: r.id },
    props: { resource: r },
  }));
}

interface Props { resource: Resource; }
const { resource: r } = Astro.props;

const all = registry.resources as Resource[];
const related = all.filter((x) => x.category === r.category && x.id !== r.id).slice(0, 3);
const tabs = makeTabs(r);

const spec: { label: string; value: string }[] = [
  { label: 'Category', value: catLabel(r.category) },
  ...(r.attribution ? [{ label: 'Author', value: r.attribution }] : []),
  { label: 'License', value: r.license },
  { label: 'Languages', value: langList(r.languages) },
  { label: 'Added', value: fmtLong(r.added) },
];
---

<Base title={r.name} description={r.description}>
  <div class="detail">
    <nav class="crumb">
      <a href="/">Directory</a>
      <span class="sep">/</span>
      <a href={`/category/${r.category}`}>{catLabel(r.category)}</a>
      <span class="sep">/</span>
      <span class="current">{r.name}</span>
    </nav>

    <header class="d-head">
      <span class="d-glyph" set:html={catIcon(r.category, 30)} />
      <div class="d-headtext">
        <div class="d-cat">{catLabel(r.category)}</div>
        <h1>{r.name}</h1>
        <p>{r.description}</p>
        <div class="d-flags">
          {r.free && <span class="flag ok"><span set:html={flagIcon('free')} />Free</span>}
          {r.auth_required && <span class="flag warn"><span set:html={flagIcon('auth')} />Auth required</span>}
          {r.maintained && <span class="flag ok"><span set:html={flagIcon('maint')} />Maintained</span>}
          {r.scholar_reviewed && <span class="flag gold"><span set:html={flagIcon('scholar')} />Scholar-reviewed</span>}
        </div>
      </div>
    </header>

    <div class="d-cta">
      <a class="cta primary" href={r.url} target="_blank" rel="noopener">Open resource ↗</a>
      {r.docs && <a class="cta" href={r.docs} target="_blank" rel="noopener">Documentation</a>}
      {r.repo && <a class="cta" href={r.repo} target="_blank" rel="noopener">Repository</a>}
    </div>

    <div class="d-body">
      <div class="d-main">
        <div>
          <h2 class="sec-title">Quick start</h2>
          <div class="code">
            <div class="code-bar">
              {tabs.map((t, i) => (
                <button class:list={['code-tab', { active: i === 0 }]} data-tab={i}>{t.label}</button>
              ))}
              <div style="flex:1"></div>
              <button id="copy-btn" class="copy"><span set:html={ICONS.copy} /><span class="copy-label">Copy</span></button>
            </div>
            {tabs.map((t, i) => (
              <pre class="code-pane" data-pane={i} hidden={i !== 0}><code>{t.code}</code></pre>
            ))}
          </div>
        </div>

        {related.length > 0 && (
          <div>
            <h2 class="sec-title">Related in {catLabel(r.category)}</h2>
            <div class="related">
              {related.map((x) => (
                <a class="rel" href={`/resources/${x.id}`} aria-label={x.name}>
                  <span class="rel-glyph" set:html={catIcon(x.category, 18)} />
                  <div class="rel-name">{x.name}</div>
                  <p class="rel-desc">{x.description}</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <aside class="d-side">
        <h2 class="sec-title">Details</h2>
        <div class="side-label">Format</div>
        <div class="side-formats"><span class="rc-format">{r.format}</span></div>
        {spec.map((row) => (
          <div class="spec-row">
            <span class="spec-k">{row.label}</span>
            <span class="spec-v">{row.value}</span>
          </div>
        ))}
        {r.tags.length > 0 && (
          <>
            <div class="side-label" style="margin-top:16px">Tags</div>
            <div class="side-tags">
              {r.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </>
        )}
      </aside>
    </div>
  </div>
</Base>

<style>
  .detail { max-width: 1080px; margin: 0 auto; padding: 30px 24px 72px; }
  .crumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--noor-muted); margin-bottom: 24px; flex-wrap: wrap; }
  .crumb a { color: var(--noor-muted); transition: color 0.15s; }
  .crumb a:hover { color: var(--noor-gold); }
  .crumb .sep { color: var(--noor-faint); }
  .crumb .current { color: var(--noor-fg); }

  .d-head { display: flex; align-items: flex-start; gap: 18px; margin-bottom: 24px; flex-wrap: wrap; }
  .d-glyph {
    width: 62px; height: 62px; border-radius: 15px; flex: none;
    background: var(--noor-gold-soft); color: var(--noor-gold);
    display: inline-flex; align-items: center; justify-content: center;
  }
  .d-headtext { flex: 1; min-width: 240px; }
  .d-cat { font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--noor-faint); font-weight: 600; margin-bottom: 4px; }
  .d-headtext h1 { margin: 0 0 9px; font-size: clamp(26px, 3.2vw, 36px); font-weight: 700; color: var(--noor-fg); letter-spacing: -0.4px; }
  .d-headtext p { margin: 0; font-size: 16px; line-height: 1.55; color: var(--noor-muted); max-width: 680px; text-wrap: pretty; }
  .d-flags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 15px; }
  .flag { display: inline-flex; align-items: center; gap: 5px; font-size: 11.5px; font-weight: 500; border-radius: 999px; padding: 3px 10px; }
  .flag.ok { color: var(--ok); background: color-mix(in oklab, var(--ok) 13%, transparent); border: 1px solid color-mix(in oklab, var(--ok) 28%, transparent); }
  .flag.warn { color: var(--warn); background: color-mix(in oklab, var(--warn) 13%, transparent); border: 1px solid color-mix(in oklab, var(--warn) 28%, transparent); }
  .flag.gold { color: var(--noor-gold); background: var(--noor-gold-soft); border: 1px solid var(--noor-gold-dim); }

  .d-cta { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 32px; }
  .cta {
    display: inline-flex; align-items: center; gap: 8px; padding: 11px 18px; border-radius: 10px;
    border: 1px solid var(--noor-border); background: var(--noor-card); color: var(--noor-fg);
    font-weight: 600; font-size: 14px; transition: border-color 0.15s, color 0.15s, filter 0.15s, box-shadow 0.15s;
  }
  .cta:hover { border-color: var(--noor-gold-dim); color: var(--noor-gold); }
  .cta.primary {
    padding: 11px 19px; border-color: var(--noor-gold-dim);
    background: var(--noor-gold-grad); color: var(--noor-ink);
  }
  .cta.primary:hover { filter: brightness(1.05); box-shadow: 0 6px 20px var(--noor-gold-soft); color: var(--noor-ink); }

  .d-body { display: grid; grid-template-columns: 1fr 308px; gap: 30px; align-items: start; }
  .d-main { min-width: 0; display: flex; flex-direction: column; gap: 32px; }
  .sec-title { margin: 0 0 12px; font-size: 13px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--noor-faint); font-weight: 600; }

  .code { border: 1px solid var(--noor-border); border-radius: 14px; overflow: hidden; background: var(--noor-bg2); }
  .code-bar { display: flex; align-items: center; gap: 2px; border-bottom: 1px solid var(--noor-border-soft); background: var(--noor-card); padding: 6px; }
  .code-tab {
    padding: 6px 13px; border-radius: 8px; border: none; background: transparent;
    color: var(--noor-muted); font-size: 12.5px; font-weight: 500; font-family: var(--mono); cursor: pointer;
  }
  .code-tab:hover { color: var(--noor-fg); }
  .code-tab.active { background: var(--noor-bg2); color: var(--noor-gold); font-weight: 600; }
  .copy {
    display: inline-flex; align-items: center; gap: 6px; padding: 6px 11px; border-radius: 8px;
    border: 1px solid var(--noor-border-soft); background: var(--noor-bg2); color: var(--noor-muted);
    font-size: 12px; cursor: pointer; font-family: var(--mono); transition: color 0.15s, border-color 0.15s;
  }
  .copy:hover { color: var(--noor-gold); border-color: var(--noor-gold-dim); }
  .code-pane { margin: 0; padding: 18px; overflow: auto; font-family: var(--mono); font-size: 12.5px; line-height: 1.75; color: var(--noor-fg); }

  .related { display: grid; grid-template-columns: repeat(auto-fill, minmax(232px, 1fr)); gap: 14px; }
  .rel {
    display: flex; flex-direction: column; gap: 8px; padding: 15px; border-radius: 12px;
    border: 1px solid var(--noor-border); background: var(--noor-card);
    transition: border-color 0.15s, transform 0.15s;
  }
  .rel:hover { border-color: var(--noor-gold-dim); transform: translateY(-2px); }
  .rel:focus-visible { border-color: var(--noor-gold); box-shadow: 0 0 0 3px var(--noor-gold-soft); outline: none; }
  .rel-glyph { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 9px; background: var(--noor-gold-soft); color: var(--noor-gold); }
  .rel-name { font-size: 14px; font-weight: 700; color: var(--noor-fg); line-height: 1.25; }
  .rel-desc { margin: 0; font-size: 12px; line-height: 1.45; color: var(--noor-muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .d-side { padding: 20px; border-radius: 14px; border: 1px solid var(--noor-border); background: var(--noor-card); position: sticky; top: 80px; }
  .side-label { font-size: 11px; color: var(--noor-muted); margin-bottom: 7px; }
  .side-formats { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
  .rc-format { font-family: var(--mono); font-size: 11px; color: var(--noor-muted); background: var(--noor-bg2); border: 1px solid var(--noor-border-soft); border-radius: 6px; padding: 2px 8px; }
  .spec-row { display: flex; justify-content: space-between; gap: 12px; padding: 9px 0; border-top: 1px solid var(--noor-border-soft); font-size: 13px; }
  .spec-k { color: var(--noor-muted); }
  .spec-v { color: var(--noor-fg); text-align: right; font-weight: 500; }
  .side-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag { font-size: 11px; color: var(--noor-muted); background: var(--noor-bg2); border: 1px solid var(--noor-border-soft); border-radius: 999px; padding: 2px 9px; }

  @media (max-width: 880px) {
    .d-body { grid-template-columns: 1fr; }
    .d-side { position: static; }
  }
</style>

<script>
  (function () {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.code-tab'));
    const panes = Array.from(document.querySelectorAll<HTMLElement>('.code-pane'));
    const copyBtn = document.getElementById('copy-btn');
    const copyLabel = copyBtn?.querySelector('.copy-label');
    if (!tabs.length) return;

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const i = tab.dataset.tab;
        tabs.forEach((t) => t.classList.toggle('active', t === tab));
        panes.forEach((p) => (p.hidden = p.dataset.pane !== i));
      });
    });

    let resetTimer: ReturnType<typeof setTimeout>;
    copyBtn?.addEventListener('click', () => {
      const active = panes.find((p) => !p.hidden);
      if (!active) return;
      const text = active.textContent || '';
      try { navigator.clipboard.writeText(text); } catch (e) {}
      if (copyLabel) copyLabel.textContent = 'Copied!';
      clearTimeout(resetTimer);
      resetTimer = setTimeout(() => { if (copyLabel) copyLabel.textContent = 'Copy'; }, 1500);
    });
  })();
</script>
